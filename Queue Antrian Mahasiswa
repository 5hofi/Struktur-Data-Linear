from collections import deque
queue = deque()
def enqueue(nama):
    queue.append(nama)
    print(nama, "telah masuk kedalam antrian.")
def dequeue():
    if queue:
        nama = queue.popleft()
        print(nama,"telah dilayani dan keluar dari antrian.")
    else:
        print("Antrian kosong, tidak ada yang bisa dilayani,")
def tampilkan():
    print("Antrian saat ini: ", queue)
enqueue("Opi")
enqueue("Ila")
enqueue("Dwi")
tampilkan()
dequeue()
tampilkan()
